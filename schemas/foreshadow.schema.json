{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "chaseNovel Foreshadow Item",
  "type": "object",
  "required": ["id", "seed_chapter", "content", "status"],
  "properties": {
    "id": { "type": "string" },
    "seed_chapter": { "type": "integer", "minimum": 0 },
    "content": { "type": "string" },
    "who_knows": { "type": "string" },
    "trigger_condition": { "type": "string" },
    "invalid_condition": { "type": "string" },
    "due_chapter": { "type": ["integer", "null"], "minimum": 0 },
    "last_reminder_chapter": { "type": ["integer", "null"], "minimum": 0 },
    "reader_memory_heat": { "type": "string", "enum": ["high", "medium", "low", "unknown"] },
    "payoff_type": { "type": "string", "enum": ["plot", "emotion", "relationship", "worldbuilding", "unknown"] },
    "status": { "type": "string", "enum": ["active", "triggered", "resolved", "delayed", "abandoned"] }
  },
  "additionalProperties": true
}

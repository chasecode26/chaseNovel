  "id": "scene_suspense_001",
  "scene": "suspense",
  "goal": "制造悬念，但不靠故弄玄虚和空泛留白。",
  "steps": [
    "先给可疑事实",
    "再限制信息量",
    "再给角色误判或暂时判断",
    "最后留下未闭合缺口"
  ],
  "avoid": [
    "只说不对劲",
    "强行神秘化",
    "没有新信息只留空白"
  ],
  "applicable_genres": [
    "悬疑/推理",
    "无限流/副本流"
  ],
  "notes": [
    "适合案情推进、规则异常、身份疑点等场景"
  ]
}

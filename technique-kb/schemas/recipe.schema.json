{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chaseNovel.local/technique-kb/recipe.schema.json",
  "title": "Technique Recipe",
  "type": "object",
  "required": [
    "id",
    "scene",
    "goal",
    "steps",
    "avoid",
    "applicable_genres"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "scene": {
      "type": "string"
    },
    "goal": {
      "type": "string"
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "avoid": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "applicable_genres": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}

{
  "name": "chase-novel-writing-workbench",
  "version": "1.4.0",
  "description": "Workflow and tooling for the chaseNovel writing skill.",
  "license": "MIT",
  "bin": {
    "chase": "./bin/chase.js"
  },
  "files": [
